<?php

declare(strict_types=1);

namespace {{ namespace }};

use Mosaiqo\Proofread\Assertions\ContainsAssertion;
use Mosaiqo\Proofread\Contracts\Assertion;
use Mosaiqo\Proofread\Suite\EvalSuite;
use Mosaiqo\Proofread\Support\Dataset;

final class {{ class }} extends EvalSuite
{
    public function name(): string
    {
        return '{{ class }}';
    }

    public function dataset(): Dataset
    {
        return Dataset::make('{{ class }}', [
            ['input' => 'example-input', 'expected' => 'example-output'],
        ]);
    }

    public function subject(): mixed
    {
        // Replace with your Agent class-string or a callable.
        return static fn (string $input): string => $input;
    }

    /**
     * @return array<int, Assertion>
     */
    public function assertions(): array
    {
        return [
            ContainsAssertion::make('example-output'),
        ];
    }
}
